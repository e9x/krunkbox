{
  "compilerOptions": {
    "target": "ESNext",
    "types": ["node"],
    "lib": ["ESNext"],
    "strict": true,
    "sourceMap": true,
    "noEmit": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "paths": {
      "~client/*": ["../client/*"],
    },
  },
  "include": ["./**/*"],
}
