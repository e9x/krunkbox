{
	"compilerOptions": {
		"outDir": "dist",
		"target": "ES2022",
		"lib": ["DOM", "DOM.Iterable", "ES2018"],
		"baseUrl": "src",
		"strict": true,
		"stripInternal": true,
		"module": "ESNext",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true
	},
	"include": ["src/**/*"]
}
