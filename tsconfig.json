{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ESNext",
    "types": ["node"],
    "lib": ["ESNext"],
    "baseUrl": "src",
    "strict": true,
    "stripInternal": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"]
}
